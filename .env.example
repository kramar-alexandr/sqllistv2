# ── MSSQL container ───────────────────────────────────────────────────────────
# Пароль SA — используется и контейнером MSSQL, и приложением sqllist
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Имя базы данных (ERP создаёт её при первом подключении)
DB_NAME=HW

# ── Порты ─────────────────────────────────────────────────────────────────────
# Порт HTTP для доступа к спискам (браузер)
HTTP_PORT=3001

# Порт MSSQL — открыт для зеркалирования ERP-системы
MSSQL_PORT=1433
